  "keyFeatures": [
    "Framework-agnostic core with adapters for React, Vue, Solid, Svelte, and Angular",
    "Automatic caching with smart background refetching and stale-while-revalidate strategy",
    "Powerful query invalidation and cache management",
    "Infinite queries and paginated data support",
    "Optimistic updates and mutations with automatic rollback",
    "Request deduplication and query cancellation",
    "React Suspense and streaming SSR support",
    "Built-in devtools for debugging",
    "TypeScript-first with complete type safety",
    "Zero dependencies and tiny bundle size"
  ],
